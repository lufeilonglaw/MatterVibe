{
  "name": "mattervibe",
  "productName": "MatterVibe",
  "version": "1.3.1",
  "description": "MatterVibe —— 以案件为中心的本地任务管理 Mac 客户端（SQLite3 单文件存储）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "npx --yes @electron/packager . MatterVibe --platform=darwin --arch=arm64 --overwrite --icon=assets/icon.icns --out=dist",
    "pack:win": "npx --yes @electron/packager . MatterVibe --platform=win32 --arch=x64 --overwrite --icon=assets/icon.ico --out=dist",
    "pack:winarm": "npx --yes @electron/packager . MatterVibe --platform=win32 --arch=arm64 --overwrite --icon=assets/icon.ico --out=dist"
  },
  "author": "Feilong",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7"
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  }
}
